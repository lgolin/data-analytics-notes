## Log Transformation on Mammals Dataset
```r
library(openintro)

# Plot BEFORE transformation — very skewed!
p01 <- qplot(mammals$body_wt,  geom = "density", main = "Body weight (original)")
p02 <- qplot(mammals$brain_wt, geom = "density", main = "Brain weight (original)")
gridExtra::grid.arrange(p01, p02, nrow = 1)

# Apply the log transformation
mammals$log_body_wt  <- log(mammals$body_wt)
mammals$log_brain_wt <- log(mammals$brain_wt)

# Plot AFTER transformation — much more normal!
p03 <- qplot(mammals$log_body_wt,  geom = "density", main = "Body weight (log)")
p04 <- qplot(mammals$log_brain_wt, geom = "density", main = "Brain weight (log)")
gridExtra::grid.arrange(p03, p04, nrow = 1)

# Build linear regression model on ORIGINAL data
model1 <- lm(body_wt ~ brain_wt, data = mammals)
r_sq1  <- cor(model1$fitted.values, mammals$body_wt) ^ 2
cat("R-squared (original):", round(r_sq1, 3), "\n")

# Build linear regression model on LOG-TRANSFORMED data
model2 <- lm(log_body_wt ~ log_brain_wt, data = mammals)
r_sq2  <- cor(model2$fitted.values, mammals$log_body_wt) ^ 2
cat("R-squared (log transformed):", round(r_sq2, 3), "\n")
# Result: R² improves from ~0.87 to ~0.92 — a 35% improvement!
```

