# R Code Summary

``` r
library(forecast)

# 1. Load and plot
ts_data <- AirPassengers
autoplot(ts_data)

# 2. Decompose
dec_add  <- decompose(ts_data, type = "additive")
dec_mult <- decompose(ts_data, type = "multiplicative")
plot(dec_add)
plot(dec_mult)

# 3. Standardise and plot residuals
res <- dec_mult$random
std_res <- (res - mean(res, na.rm=TRUE)) / sd(res, na.rm=TRUE)
par(mfrow=c(2,2))
hist(std_res); boxplot(std_res)
qqnorm(std_res); qqline(std_res, col="red")
plot(std_res); abline(h=c(-2,2), col="blue", lty=2)

# 4. Auto ETS
best <- ets(ts_data)
summary(best)

# 5. Holt-Winters models
hw1 <- hw(ts_data, h=24, seasonal="additive")
hw2 <- hw(ts_data, h=24, seasonal="multiplicative", damped=FALSE)
hw3 <- hw(ts_data, h=24, seasonal="multiplicative", damped=TRUE)

# 6. Compare metrics
accuracy(hw1); accuracy(hw2); accuracy(hw3)
```

