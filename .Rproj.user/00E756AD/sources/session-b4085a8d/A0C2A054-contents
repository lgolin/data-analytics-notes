# Key Formulas Reference

```r
# Standard Error of the Mean
SEM <- sigma / sqrt(n)

# 95% Confidence Interval (known sigma)
CI_lower <- x_bar - 1.96 * (sigma / sqrt(n))
CI_upper <- x_bar + 1.96 * (sigma / sqrt(n))

# Sample size for given margin of error
n <- (z_alpha_half * sigma / MoE)^2   # round up

# Cohen's d (two samples)
d <- (mean1 - mean2) / s_pooled

# Cohen's d (one sample)
d <- (x_bar - mu0) / sigma

# Power (1-sample z-test, using asbio)
library(asbio)
power.z.test(sigma, n, alpha, effect, test = "two.tail")

# Power (t-test, using pwr)
library(pwr)
pwr.t.test(n, d, sig.level, power, type, alternative)

# Power = 1 - beta
Power <- 1 - beta
```

