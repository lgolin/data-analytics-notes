## Helper Function: Draw All Three Plots at Once
```r
library(ggplot2)
library(gridExtra)

drawPlots <- function(data, title) {
  # Histogram with mean (blue) and median (green) lines
  p01 <- qplot(data, geom = "histogram", bins = 100) +
    geom_vline(xintercept = mean(data),   size = 2, color = "blue") +
    geom_vline(xintercept = median(data), size = 2, color = "green")

  # Density plot with mean (blue) and median (green) lines
  p02 <- qplot(data, geom = "density") +
    geom_vline(xintercept = mean(data),   size = 2, color = "blue") +
    geom_vline(xintercept = median(data), size = 2, color = "green")

  # Boxplot with mean shown as blue dot
  p03 <- qplot(data, geom = "boxplot") +
    coord_flip() +
    geom_point(aes(x = mean(data), y = 0), size = 3, color = "blue")

  gridExtra::grid.arrange(p01, p02, p03, nrow = 1, top = title)
}

# Try it on different distributions:
drawPlots(rnorm(10000, mean = 0, sd = 1),   "Normal distribution")
drawPlots(rbeta(10000, 5, 1),               "Left skewed")
drawPlots(rbeta(10000, 1, 5),               "Right skewed")
```

> 💡 **Blue line = mean. Green line = median.**
> When they are far apart → skewed data!

