# Code block 2
library(rpart)
library(rpart.plot)
library(titanic)

data(titanic_train)
set.seed(42)

# split data into two sets, 90% used for training, 10% for evaluation
nobs <- nrow(titanic_train)
train <- sample(nobs, 0.9*nobs)
test <- setdiff(seq_len(nobs),train)

# select columns to use to train and predict for
target <- "Survived"
colsToIgnore <- c("PassengerId","Name","Cabin","Ticket")
input <- setdiff(names(titanic_train),c(target,colsToIgnore))






# Code block 3
# fix problem with 2 rows with empty data for Embarked
titanic_train[titanic_train$Embarked=="",]$Embarked = "S"

train_data <- titanic_train[train, c(input, target)]
test_data <- titanic_train[test, c(input, target)]

# fill in missing ages ,note how we get the mean of the training data
meanAge <- mean(train_data$Age,na.rm=TRUE)
train_data[is.na(train_data$Age),]$Age <- meanAge
test_data[is.na(test_data$Age),]$Age <- meanAge





# Code block 4
# we are predicting on the 'Survived' field,
#  using the rows in train and the columns in the input array
rpart <- rpart(Survived ~ .,data=train_data,method="class")

# get predicted values for the TEST set
pr <- predict(rpart, newdata=test_data,type="class")
# generate the confusion matrix
tab <- table(pr,test_data$Survived)
# columns are ACTUALS, ROWS are PREDICTED
accuracy <- 100 * sum(diag(tab) / sum(tab))

print(tab)
print(accuracy)





# Code block 5
print (tab)





# Code block 6
actuals <- factor(titanic_train[test,]$Survived,levels=c(1,0))
pr <- factor(pr,levels=c(1,0))
tab <- table(pr,actuals)
print (tab)





# Code block 7
print(tab)
TP <- tab[1,1];FP <- tab[1,2];FN <- tab[2,1];TN <- tab[2,2]
lines <- sprintf("True Positive=%i, i.e. those who did survive AND model agreed ", TP)
lines <- c(lines,sprintf("False Positive=%i, i.e. those who did NOT survive BUT the model predicted they did survive: ", FP))
lines <- c(lines,sprintf("False Negative=%i, i.e. those who did survive BUT the model thought they did not survive: ", FN))
lines <- c(lines,sprintf("True Negative=%i, i.e. those who did NOT survive AND model agreed: ", TN))
cat(paste(lines, collapse='\n'))





# Code block 8
precision <- TP / (TP+FP)
recall <- TP / (TP+FN)
F1 <- 2 * (precision * recall) / (precision + recall)
lines <- sprintf("Precision=%i / (%i+%i) = %.2f ", TP,TP,FP,precision)
lines <- c(lines,sprintf("Recall=%i / (%i+%i) = %.2f ", TP,TP,FN,recall))
lines <- c(lines,sprintf("F1 = %.2f ", F1))
cat(paste(lines, collapse='\n'))





