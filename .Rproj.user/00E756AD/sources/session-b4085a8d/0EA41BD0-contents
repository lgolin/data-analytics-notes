# Code block 15
titanic_DT <- function(titanic_train,seed)
{
  set.seed(seed) # for reproducability
  # split data into two sets, 90% used for training, 10% for evaluation
  nobs <- nrow(titanic_train)
  train <- sample(nobs, 0.9*nobs)
  test <- setdiff(seq_len(nobs),train)
  
  # select columns to use to train and predict for
  target <- "Survived"
  colsToIgnore <- c("PassengerId","Name","Cabin","Ticket","Age")
  input <- setdiff(names(titanic_train),c(target,colsToIgnore))
  train_data <- titanic_train[train, c(input, target)]
  test_data <- titanic_train[test, c(input, target)]

  rpart <- rpart(Survived ~ .,data=train_data,method="class")
  pr <- predict(rpart, newdata=test_data,type="class")
  tab <- table(pr,test_data$Survived)
  accuracy <- 100 * sum(diag(tab) / sum(tab))
  return(accuracy)
}





