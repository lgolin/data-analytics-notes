# Code block 14
# create a prior belief
prior <- table(train_data$Survived) / nrow(train_data)
sprintf("Our prior belief is the overall probability someone survived = %.2f", prior[2])

#now lets calculate the probability that a woman in first class survived
tab <- table(train_data$Sex,train_data$Survived)
likelihood <- tab[1,] / sum(tab[1,])
sprintf("The probability that a woman survived = %.2f", likelihood[2])
posterior <- prior * likelihood / sum(prior * likelihood)
sprintf("Posterior probability (person was a woman) is  = %.2f", posterior[2])





# Code block 15
# our old posterior becomes our new prior
prior <- posterior
tab <- table(train_data$Pclass,train_data$Survived)
likelihood <- tab[1,] / sum(tab[1,])
sprintf("The probability that a first class passenger survived = %.2f", likelihood[2])
posterior <- prior * likelihood / sum(prior * likelihood)
sprintf("Posterior probability (person was a woman AND in 1st class) is  = %.2f", posterior[2])
# See http://psych.fullerton.edu/mbirnbaum/bayes/BayesCalc.htm





