library(titanic)
library(tidymodels)

data(titanic_train)
head(titanic_train)


table(titanic_train$Embarked)

titanic_train[titanic_train$Embarked=="",]$Embarked = "S"

# A pre-defined value is used to reset the random seed 
# so that results are repeatable.
set.seed(42)
str(titanic_train)
summary(titanic_train)

# split data into two sets, 90% used for training, 10% for evaluation
nobs <- nrow(titanic_train)
train <- sample(nobs, 0.9*nobs)
test <- setdiff(seq_len(nobs),train)

# select columns to use to train and predict for
names(titanic_train)
target <- "Survived"
colsToIgnore <- c("PassengerId","Name","Cabin","Ticket","Age")
input <- setdiff(names(titanic_train),c(target,colsToIgnore))
input

# subset the data by row AND column
# then use that in the model build stage
train_data <- titanic_train[train, c(input, target)]
test_data <- titanic_train[test, c(input, target)]

# we are predicting on the 'Survived' field,
#  using the rows in train and the columns in the input array
logistic_model <- glm(formula = Survived ~ .,
                      family = binomial(link = "logit"), 
                      data = train_data)
summary(logistic_model)
logistic_model$coefficients

# get predicted values for the TEST set
pr <- predict(logistic_model, newdata=test_data,type="response")
pr

pr <- ifelse(pr > 0.5,1,0)
pr
# generate the confusion matrix with survived as the positive class
actuals <- factor(test_data$Survived,levels=c(1,0))
pr <- factor(pr,levels=c(1,0))
tab1 <- table(pr,actuals)
# columns are ACTUALS, ROWS are PREDICTED
tab1
accuracy <- 100 * sum(diag(tab1) / sum(tab1))
accuracy

# roc curve and pr curve
pr <- predict(logistic_model, newdata=test_data,type="response")
test_data$predicted <- pr
test_data$Survived <- factor(test_data$Survived,levels=c(1,0))
auc <- roc_auc(test_data,Survived,predicted)
auc
roc <- roc_curve(test_data,Survived,predicted)
autoplot(roc)
pr <- pr_curve(test_data,Survived,predicted)
autoplot(pr)



#####
# changing the threshold
threshold <- 0.5
pr <- predict(logistic_model, newdata=test_data,type="response")
pr <- ifelse(pr >= threshold,1,0)
pr <- factor(pr,levels=c(1,0))
tab <- table(pr,actuals)
tab
accuracy <- 100 * sum(diag(tab) / sum(tab))
accuracy
TP <- tab[1,1]
FN <- tab[2,1]
FP <- tab[1,2]
precision <- round(TP / (TP+FP),2)
recall <- round(TP / (TP+FN),2)
sprintf("Using a cut-off of %.2f, precision=%.2f and recall=%.2f", threshold,precision,recall)

