###################################################
#                                                 #
#                                                 #
# Part 1: Decision trees on Iris dataset          #
#                                                 #
#                                                 #
###################################################




data(iris)
head(iris)

# data exploration
ggpairs(iris,columns=c(1,2,3,4),
        mapping=aes(colour=Species, alpha=0.5))
str(iris)
summary(iris)

# set the random seed, so that results are repeatable.
set.seed(1987)
# split data into two sets, 90% used for training, 10% for evaluation
nobs <- nrow(iris)
train <- sample(nobs, 0.9*nobs)
test <- setdiff(seq_len(nobs),train)

table(iris[test,]$Species)

# select columns to use to train and predict for
names(iris)
target <- "Species"
input <- setdiff(names(iris),target)
input

# build the tree
# we are predicting on the 'Species' field,
#  using the rows in train and the columns in the input array
rpart <- rpart(Species ~ .,
               data=iris[train, c(input, target)],
               method="class")

# Generate a textual view of the Decision Tree model.
print(rpart)

# plot the tree
rpart.plot(rpart,main="Decision Tree iris $ Survived")

test_data <- iris[test,]

# get predicted values for the TEST set
pr <- predict(rpart, newdata=iris[test, c(input, target)],type="class")

# check results
as.character(iris[test,]$Species) # actual data
as.character(pr)    # predicted data

# generate the confusion matrix
# columns are ACTUALS, ROWS are PREDICTED
tab <- table(pr, iris[test,]$Species,dnn=c("Predicted","Actual"))
tab
accuracy <- 100 * sum(diag(tab) / sum(tab))
accuracy


